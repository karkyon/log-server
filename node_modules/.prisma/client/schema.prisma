generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ユーザー（CMSログインユーザー）
model User {
  id              String          @id @default(uuid())
  username        String          @unique
  passwordHash    String          @map("password_hash")
  displayName     String          @map("display_name")
  role            UserRole        @default(MEMBER)
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  memberships     ProjectMember[]
  createdProjects Project[]       @relation("CreatedBy")

  @@map("users")
}

enum UserRole {
  ADMIN
  MEMBER
}

// ─── プロジェクト（監視対象アプリ単位）
model Project {
  id          String           @id @default(uuid())
  slug        String           @unique
  name        String
  description String?
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  createdById String           @map("created_by_id")
  createdBy   User             @relation("CreatedBy", fields: [createdById], references: [id])
  members     ProjectMember[]
  apiKeys     ApiKey[]
  traces      Trace[]
  settings    ProjectSettings?
  screenshots Screenshot[]
  consoleLogs ConsoleLog[]
  patterns    Pattern[]
  issues      Issue[]

  @@map("projects")
}

// ─── プロジェクトメンバー
model ProjectMember {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  role      String   @default("VIEWER")
  createdAt DateTime @default(now()) @map("created_at")
  project   Project  @relation(fields: [projectId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@map("project_members")
}

// ─── APIキー（SDK認証用）
model ApiKey {
  id         String    @id @default(uuid())
  projectId  String    @map("project_id")
  keyHash    String    @unique @map("key_hash")
  label      String?
  isActive   Boolean   @default(true) @map("is_active")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  project    Project   @relation(fields: [projectId], references: [id])
  traces     Trace[]

  @@map("api_keys")
}

// ─── トレース（ユーザー1操作セッション = 1 TraceID）
model Trace {
  id          String       @id @default(uuid())
  projectId   String       @map("project_id")
  apiKeyId    String       @map("api_key_id")
  operatorId  String?      @map("operator_id")
  status      TraceStatus  @default(ACTIVE)
  startedAt   DateTime     @default(now()) @map("started_at")
  endedAt     DateTime?    @map("ended_at")
  metadata    Json?
  project     Project      @relation(fields: [projectId], references: [id])
  apiKey      ApiKey       @relation(fields: [apiKeyId], references: [id])
  logs        Log[]
  screenshots Screenshot[]
  consoleLogs ConsoleLog[]
  issues      Issue[]

  @@map("traces")
}

enum TraceStatus {
  ACTIVE
  COMPLETED
  TIMEOUT
  ERROR
}

// ─── ログ（各操作イベント）
model Log {
  id             String      @id @default(uuid())
  traceId        String?     @map("trace_id")
  eventType      String      @map("event_type")
  screenName     String?     @map("screen_name")
  elementId      String?     @map("element_id")
  payload        Json?
  screenshotPath String?     @map("screenshot_path")
  timestamp      DateTime    @default(now())
  trace          Trace?      @relation(fields: [traceId], references: [id])
  verdict        LogVerdict?

  @@map("logs")
}

// ─── プロジェクト設定
model ProjectSettings {
  projectId      String   @id @map("project_id")
  logLevel       String   @default("INFO") @map("log_level")
  retentionDays  Int      @default(90) @map("retention_days")
  sessionTimeout Int      @default(1800) @map("session_timeout")
  updatedAt      DateTime @updatedAt @map("updated_at")
  project        Project  @relation(fields: [projectId], references: [id])

  @@map("project_settings")
}

// ─── スクリーンショット
model Screenshot {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  traceId   String   @map("trace_id")
  featureId String   @map("feature_id")
  filePath  String   @map("file_path")
  ts        DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id])
  trace     Trace    @relation(fields: [traceId], references: [id])

  @@index([projectId, traceId])
  @@map("screenshots")
}

// ─── コンソールログ
model ConsoleLog {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  traceId   String   @map("trace_id")
  featureId String   @map("feature_id")
  level     String
  args      Json
  stack     String?
  ts        DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id])
  trace     Trace    @relation(fields: [traceId], references: [id])

  @@index([projectId, featureId])
  @@map("console_logs")
}

// ─── 作業パターン
model Pattern {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  name        String
  screenMode  String?  @map("screen_mode")
  seqData     Json     @map("seq_data")
  status      String   @default("未評価")
  memo        String?
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  project     Project  @relation(fields: [projectId], references: [id])

  @@map("patterns")
}

// ─── チケット
model Issue {
  id            String   @id @default(uuid())
  projectId     String   @map("project_id")
  traceId       String?  @map("trace_id")
  featureId     String   @map("feature_id")
  title         String
  type          String
  priority      String
  status        String   @default("未対応")
  description   String?
  logIds        Json?    @map("log_ids")
  screenshotIds Json?    @map("screenshot_ids")
  assignedToId  String?  @map("assigned_to_id")
  webhookSent   Boolean  @default(false) @map("webhook_sent")
  createdById   String?  @map("created_by_id")
  updatedById   String?  @map("updated_by_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  project       Project  @relation(fields: [projectId], references: [id])
  trace         Trace?   @relation(fields: [traceId], references: [id])

  @@index([projectId, featureId])
  @@index([projectId, traceId])
  @@map("issues")
}

model LogVerdict {
  id        String   @id @default(uuid())
  logId     String   @unique @map("log_id")
  verdict   String   @default("OK")
  issueType String?  @map("issue_type")
  priority  String?
  status    String?
  content   String?
  memo      String?
  updatedAt DateTime @updatedAt @map("updated_at")
  log       Log      @relation(fields: [logId], references: [id], onDelete: Cascade)

  @@map("log_verdicts")
}
